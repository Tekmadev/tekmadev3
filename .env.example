# Copy to .env.local for local dev, and set these in Vercel Project Settings → Environment Variables.
# Everything here is optional — the site builds and runs without any of it. Each
# feature simply activates once its key is present.

# --- PostHog (cookieless behavioral analytics: page views, clicks, journeys) ---
# Project API key (starts with "phc_"), from PostHog → Settings → Project.
NEXT_PUBLIC_POSTHOG_KEY=
# Use https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU). Defaults to US.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Stripe (private pricing page → checkout) — to be added later ---
# Secret key (server-only, NEVER prefixed NEXT_PUBLIC). From Stripe → Developers → API keys.
STRIPE_SECRET_KEY=
# Price IDs (start with "price_") for each published tier's monthly subscription.
STRIPE_PRICE_CONVERT=
STRIPE_PRICE_GROW=
# Optional one-time setup-fee price IDs, if billed via Stripe.
STRIPE_SETUP_CONVERT=
STRIPE_SETUP_GROW=
