# Template only. Copy to .env.local (gitignored) for local dev, and set the real
# values in Vercel Project Settings -> Environment Variables for production.
#
# THIS FILE IS COMMITTED TO GIT. Never put a real secret here, placeholders only.
#
# Everything is optional: the site builds and runs without any of it. Each
# feature activates once its key is present.

# --- PostHog (behavioral analytics: page views, clicks, journeys) ---
# Project API key (starts with "phc_"), from PostHog -> Settings -> Project.
NEXT_PUBLIC_POSTHOG_KEY=
# Use https://us.i.posthog.com (US) or https://eu.i.posthog.com (EU). Defaults to US.
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Stripe (private pricing page -> checkout) ---
# Secret key (server-only, NEVER prefixed NEXT_PUBLIC). From Stripe -> Developers -> API keys.
STRIPE_SECRET_KEY=
# Monthly recurring price IDs (start with "price_") for each published tier.
STRIPE_PRICE_CONVERT=
STRIPE_PRICE_GROW=
# Optional one-time setup-fee price IDs, if billed via Stripe.
STRIPE_SETUP_CONVERT=
STRIPE_SETUP_GROW=
# Signing secret for the Stripe webhook (starts with "whsec_").
# From Stripe -> Developers -> Webhooks -> your endpoint.
STRIPE_WEBHOOK_SECRET=

# --- Supabase (first-party data: leads, subscriptions, consent) ---
# Project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=
# SECRET / service-role key (server-only, bypasses RLS). NEVER prefix NEXT_PUBLIC.
# From Supabase -> Project Settings -> API Keys -> Secret keys.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin dashboard (Supabase email/password auth at /admin) ---
# Browser auth client. Same project URL, plus the PUBLISHABLE key (safe to expose).
# From Supabase -> Project Settings -> API Keys -> Publishable key (sb_publishable_...).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Comma-separated emails allowed into /admin. Empty = nobody (fails closed).
# Also disable public sign-ups in Supabase -> Authentication -> Providers -> Email.
ADMIN_EMAILS=

# --- Cal.com webhook ---
# Shared secret you set when creating the webhook in Cal. Verifies the
# X-Cal-Signature-256 HMAC. Leave blank to skip verification (not recommended).
CAL_WEBHOOK_SECRET=
